{
	"schemaVersion": 1,
	"id": "stardewravine",
	"version": "${version}",
	"name": "Stardew Ravine",
	"description": "Adds various items from Stardew Valley into Minecraft!",
	"authors": [
		"MocuryMoto!"
	],
	"contact": {
		"homepage": "https://mocury.net/",
		"sources": "https://github.com/MocuryMoto/Stardew-Ravine"
	},
	"license": "MIT",
	"icon": "assets/stardewravine/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.mocury.stardewravine.StardewRavine"
		],
		"fabric-datagen": [
			"net.mocury.stardewravine.StardewRavineDataGenerator"
		],
		"client": [
			"net.mocury.stardewravine.StardewRavineClient"
		]
	},
	"mixins": [
		"stardewravine.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~1.21",
		"java": ">=21",
		"fabric-api": "*"
	}
}